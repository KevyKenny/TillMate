# TillMate mobile app → API (no trailing slash). Restart `npx expo start` after edits.

# Hotspot: use your laptop’s IPv4 on THAT network + port 4000 (from `ipconfig`).
# ipconfig shows an ADDRESS only — not "http://". Example:
#   EXPO_PUBLIC_API_URL=http://10.68.116.78:4000
EXPO_PUBLIC_API_URL=http://192.168.43.87:4000

# If you omit the port on http://, the app adds :4000 automatically.

# Hosted API:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
